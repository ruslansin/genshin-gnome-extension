<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.genshin-resin"
          path="/org/gnome/shell/extensions/genshin-resin/">

    <key name="accounts" type="s">
      <default>"[]"</default>
      <summary>Account list (JSON)</summary>
      <description>JSON array of account objects. Each object has: name, uid, server, ltuid, ltoken, ltmid, accountId, cookieToken</description>
    </key>

    <key name="uid" type="s">
      <default>"0"</default>
      <summary>Genshin Impact UID</summary>
      <description>Your in-game Genshin Impact UID</description>
    </key>

    <key name="server" type="s">
      <default>"os_euro"</default>
      <summary>Server region</summary>
      <description>Server: os_usa, os_euro, os_asia, os_cht</description>
    </key>

    <key name="ltuid" type="s">
      <default>""</default>
      <summary>ltuid_v2 cookie value</summary>
      <description>From hoyolab.com Cookies → ltuid_v2</description>
    </key>

    <key name="ltoken" type="s">
      <default>""</default>
      <summary>ltoken_v2 cookie value</summary>
      <description>From hoyolab.com Cookies → ltoken_v2</description>
    </key>

    <key name="ltmid" type="s">
      <default>""</default>
      <summary>ltmid_v2 cookie value</summary>
      <description>From hoyolab.com Cookies → ltmid_v2 (optional)</description>
    </key>

    <key name="account-id" type="s">
      <default>""</default>
      <summary>account_id_v2 cookie value</summary>
      <description>From hoyolab.com Cookies → account_id_v2</description>
    </key>

    <key name="cookie-token" type="s">
      <default>""</default>
      <summary>cookie_token_v2 cookie value</summary>
      <description>From hoyolab.com Cookies → cookie_token_v2</description>
    </key>

    <key name="poll-interval" type="i">
      <default>300</default>
      <summary>API poll interval (seconds)</summary>
      <description>How often to fetch data from the HoYoLAB API (60-3600)</description>
    </key>

    <key name="last-resin" type="i">
      <default>0</default>
      <summary>Last known resin count</summary>
      <description>Stored after last successful API call</description>
    </key>

    <key name="max-resin" type="i">
      <default>200</default>
      <summary>Maximum resin</summary>
      <description>Maximum resin capacity from last API response</description>
    </key>

    <key name="last-update-ts" type="x">
      <default>0</default>
      <summary>Last update timestamp</summary>
      <description>Unix timestamp (seconds) of last successful API call</description>
    </key>

    <key name="panel-position" type="i">
      <default>-1</default>
      <summary>Panel position</summary>
      <description>Position in the status area (-1 = append at end, 0 = first)</description>
    </key>

    <key name="panel-box" type="s">
      <default>"right"</default>
      <summary>Panel box</summary>
      <description>Which panel box: "left", "center", or "right"</description>
    </key>

    <key name="show-account-name" type="b">
      <default>true</default>
      <summary>Show account name on panel</summary>
      <description>Whether to show the account name before the resin count on the panel label</description>
    </key>

  </schema>
</schemalist>
